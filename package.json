{
  "name": "bimmercode-planner",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint --config .eslintrc.config.js src/",
    "lint:fix": "eslint --config .eslintrc.config.js src/ --fix"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 100,
    "trailingComma": "all"
  },
  "dependencies": {
    "@mdi/font": "^7.3.67",
    "pinia": "^2.1.7",
    "vue": "^3.4.21",
    "vue-i18n": "^9.14.5",
    "vuetify": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/eslint-config-typescript": "^14.7.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.59.0",
    "vite": "^5.2.0",
    "vite-plugin-vuetify": "^2.0.3",
    "vue-tsc": "^2.0.12"
  }
}
